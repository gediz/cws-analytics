# Copy to .env and fill in. Keep .env private: it holds a live Google session cookie.

CWS_EXTENSION_ID=your-32-char-extension-id
CWS_ACCOUNT_ID=your-publisher-uuid
CWS_COOKIE=paste-your-chrome.google.com-Cookie-header-here

# Optional. Minted from the dashboard page when blank, so you normally leave these unset.
# CWS_AT=
# CWS_BL=
# CWS_SID=
# CWS_HL=en
